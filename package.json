{
  "name": "WitselBlue",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:v2025 dev:v2026",
    "dev:v2026": "cd apps/v2026 && nuxt",
    "dev:v2025": "cd apps/v2025 && PORT=3001 nuxt",
    "build": "npm-run-all build:v2026 build:v2025",
    "build:v2026": "cd apps/v2026 && nuxt build",
    "build:v2025": "cd apps/v2025 && nuxt build",
    "build:analyze": "cd apps/v2025 && ANALYZE=true nuxt build",
    "start": "cd apps/v2026 && nuxt start",
    "start:v2025": "cd apps/v2025 && nuxt start",
    "generate": "npm-run-all generate:v2026 generate:v2025",
    "generate:v2026": "cd apps/v2026 && nuxt generate",
    "generate:v2025": "cd apps/v2025 && nuxt generate"
  },
  "dependencies": {
    "@nuxtjs/pwa": "^3.3.5",
    "core-js": "^3.37.1",
    "highlight.js": "^11.11.1",
    "lottie-web": "^5.13.0",
    "nuxt": "^2.15.8",
    "nuxt-i18n": "^6.28.1",
    "p5": "^1.9.4",
    "swiper": "^5.4.5",
    "three": "^0.166.1",
    "vue": "^2.7.10",
    "vue-awesome-swiper": "^4.1.1",
    "vue-server-renderer": "^2.7.10",
    "vue-template-compiler": "^2.7.10"
  },
  "devDependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@nuxtjs/proxy": "^2.1.0",
    "@types/p5": "^1.7.6",
    "npm-run-all": "^4.1.5",
    "nuxt-gsap-module": "^2.0.0",
    "sass": "^1.90.0",
    "sass-loader": "^10.5.2",
    "vue-tsc": "^2.0.26"
  }
}
